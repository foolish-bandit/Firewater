# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GOOGLE_CLIENT_ID: Required for Google OAuth.
GOOGLE_CLIENT_ID="MY_GOOGLE_CLIENT_ID"

# GOOGLE_CLIENT_SECRET: Required for Google OAuth.
GOOGLE_CLIENT_SECRET="MY_GOOGLE_CLIENT_SECRET"

# ADMIN_EMAILS: Comma-separated list of admin email addresses.
# Admins can approve/reject user-submitted bourbon photos.
ADMIN_EMAILS="your-email@gmail.com"

# BLOB_READ_WRITE_TOKEN: Required for Vercel Blob (photo storage).
# Get this from Vercel Dashboard > Storage > Blob > Token.
BLOB_READ_WRITE_TOKEN=""

# POSTGRES_URL: Required for Vercel Postgres (photo metadata).
# Auto-injected by Vercel when you link a Postgres database.
POSTGRES_URL=""

# JWT_SECRET: Secret key for signing JWT authentication tokens.
# Generate a strong random string (e.g., openssl rand -base64 32).
# REQUIRED in production — the default dev secret is insecure.
JWT_SECRET=""
